{
  "name": "@shoyabsiddique/archlens",
  "version": "0.1.0",
  "description": "Architectural decision intelligence for AI-assisted development",
  "type": "module",
  "bin": {
    "archlens": "dist/cli/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "architecture",
    "adr",
    "ai",
    "mcp",
    "developer-tools",
    "git-hooks"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "execa": "^9.6.0",
    "glob": "^11.0.2",
    "js-yaml": "^4.1.0",
    "p-queue": "^8.1.0",
    "prompts": "^2.4.2",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.17",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^3.1.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "main": "src/index.ts",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shoyabsiddique/archlens.git"
  },
  "author": "Shoyab Siddique",
  "bugs": {
    "url": "https://github.com/shoyabsiddique/archlens/issues"
  },
  "homepage": "https://github.com/shoyabsiddique/archlens#readme"
}
